# Ambiente
NODE_ENV=production
PORT=5000
TRUST_PROXY=1
BODY_LIMIT=1mb
LOG_LEVEL=info

# Banco de dados
# Use DATABASE_URL ou as variáveis DB_* abaixo.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20

# Autenticação
JWT_SECRET=
JWT_EXPIRES_IN=24h

# CORS
# Use lista separada por vírgula quando houver mais de uma origem.
CORS_ORIGIN=

# Rate limit de login
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_IP_MAX=30
LOGIN_RATE_LIMIT_EMAIL_MAX=10

# Integrações
OPENAI_API_KEY=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
REDIS_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
